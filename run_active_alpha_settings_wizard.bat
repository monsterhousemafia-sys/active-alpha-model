:ValidatePolicyInputs
set "AA_TRADING212_POLICY=!AA_TRADING212_POLICY: =!"
set "AA_EXECUTION_POLICY_MODE=!AA_EXECUTION_POLICY_MODE: =!"
if /I not "!AA_TRADING212_POLICY!"=="conservative" if /I not "!AA_TRADING212_POLICY!"=="balanced" if /I not "!AA_TRADING212_POLICY!"=="active" if /I not "!AA_TRADING212_POLICY!"=="threshold" (
  echo [WARN] Unbekannte Trading-212-Policy "!AA_TRADING212_POLICY!". Fallback: balanced
  set "AA_TRADING212_POLICY=balanced"
)
if /I not "!AA_EXECUTION_POLICY_MODE!"=="manual" if /I not "!AA_EXECUTION_POLICY_MODE!"=="capital_curve" (
  echo [WARN] Unbekannter Execution Policy Mode "!AA_EXECUTION_POLICY_MODE!". Fallback: capital_curve
  set "AA_EXECUTION_POLICY_MODE=capital_curve"
)
exit /b 0
