set "AA_RESIDUAL_WEIGHT_FLOOR=!AA_RESIDUAL_WEIGHT_FLOOR:,=.!"

set /p "USER_RESIDUAL_SELL_MIN=Residual Sell Min Value USD [!AA_RESIDUAL_SELL_MIN_VALUE!]: "
