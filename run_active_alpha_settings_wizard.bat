set /p "USER_PAPER_CAPITAL=Paper-Start-/Fallbackkapital USD [!AA_PAPER_CAPITAL!]: "
if not "!USER_PAPER_CAPITAL!"=="" set "AA_PAPER_CAPITAL=!USER_PAPER_CAPITAL!"
set "AA_PAPER_CAPITAL=!AA_PAPER_CAPITAL:,=.!"

