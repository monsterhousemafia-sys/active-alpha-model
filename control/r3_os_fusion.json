  "pinned_apps": ["aktien", "files", "terminal", "bau", "settings", "calculator"],
  "control_toggles": [
    {"id": "network", "label_de": "Netzwerk", "feature": "network"},
    {"id": "settings", "label_de": "Einstellungen", "feature": "settings"},
    {"id": "display", "label_de": "Bildschirm", "feature": "display"},
    {"id": "lock", "label_de": "Sperren", "feature": "lock"}
  ],
  "power_actions": [
    {
      "id": "lock",
      "label_de": "Sperren",
      "detail_de": "Sitzung sperren",
      "confirm_de": null,
      "exec": ["loginctl", "lock-session"]
    },
    {
      "id": "logout",
      "label_de": "Abmelden",
      "detail_de": "Benutzer abmelden",
      "confirm_de": "Wirklich abmelden?",
      "exec": ["loginctl", "terminate-user", "{user}"],
      "fallback_exec": ["gnome-session-quit", "--logout", "--no-prompt"]
    },
    {
      "id": "reboot",
      "label_de": "Neustart",
      "detail_de": "System neu starten",
      "confirm_de": "Jetzt neu starten?",
      "exec": ["systemctl", "reboot"]
    },
    {
      "id": "shutdown",
      "label_de": "Ausschalten",
      "detail_de": "System herunterfahren",
      "confirm_de": "Jetzt ausschalten?",
      "exec": ["systemctl", "poweroff"]
    },
    {
      "id": "suspend",
      "label_de": "Ruhezustand",
      "detail_de": "Energie sparen",
      "confirm_de": "In den Ruhezustand wechseln?",
      "exec": ["systemctl", "suspend"]
    }
  ],
  "updates": {
    "label_de": "System-Updates",
    "detail_de": "Paket-Status (apt)",
    "check_cmd": ["apt", "list", "--upgradable"],
    "open_feature": "apps"
  }
}
